      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;Qwen3 8B&lt;/td&gt;
          &lt;td&gt;151,936&lt;/td&gt;
          &lt;td&gt;151,830&lt;/td&gt;
          &lt;td&gt;99.93%&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
