&lt;p&gt;&lt;strong&gt;热门方向分布&lt;/strong&gt;：&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;大模型与 LLM：32%&lt;/li&gt;
&lt;li&gt;多模态：24%&lt;/li&gt;
&lt;li&gt;强化学习与 Agent：18%&lt;/li&gt;
&lt;li&gt;机器人：15%&lt;/li&gt;
&lt;li&gt;AI 安全与对齐：11%&lt;/li&gt;
&lt;/ul&gt;
&lt;hr&gt;
&lt;h2 id=&#34;-全部参考链接&#34;&gt;📖 全部参考链接
&lt;/h2&gt;&lt;h3 id=&#34;论文&#34;&gt;论文
&lt;/h3&gt;&lt;ol&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://arxiv.org/abs/2603.03258&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;Inherited Goal Drift (arXiv:2603.03258)&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://arxiv.org/abs/2603.03252&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;Valet Testbed (arXiv:2603.03252)&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;a class=&#34;link&#34; href=&#34;https://arxiv.org/abs/2511.13720&#34;  target=&#34;_blank&#34; rel=&#34;noopener&#34;
    &gt;X-Prediction (arXiv:2511.13720)&lt;/a&gt;&lt;/li&gt;
&lt;/ol&gt;
